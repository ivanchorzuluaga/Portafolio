---
import { projects } from '@data/portfolio';
---

<section id="projects" class="min-h-[70vh] py-10 sm:py-12 md:py-16 px-4 sm:px-6 relative overflow-hidden">
  <!-- Elemento decorativo mejorado -->
  <div class="absolute top-40 -right-20 sm:right-0 w-72 sm:w-96 h-72 sm:h-96 bg-accent-ember/[0.06] rounded-full blur-3xl pointer-events-none"></div>
  
  <div class="max-w-5xl mx-auto">
    <!-- Título con diseño mejorado responsive -->
    <div class="mb-8 sm:mb-10 md:mb-12 animate-on-scroll">
      <div class="flex flex-col xs:flex-row xs:items-center gap-3 sm:gap-5 mb-4 sm:mb-5">
        <span class="text-accent-ember font-mono text-xs sm:text-sm font-bold px-2.5 sm:px-3 py-1 sm:py-1.5 bg-accent-ember/10 border-2 border-accent-ember/30 rounded-lg shadow-lg shadow-accent-ember/10 w-fit">[ 02 ]</span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black worn-text text-wasteland-sand">
          Proyectos
        </h2>
      </div>
      <div class="flex items-center gap-3 sm:gap-5 ml-0 xs:ml-16 sm:ml-20">
        <div class="w-12 sm:w-16 h-0.5 sm:h-1 bg-gradient-to-r from-accent-ember via-accent-amber to-transparent shadow-[0_0_12px_rgba(255,59,13,0.3)]"></div>
        <p class="text-wasteland-sand/70 font-medium text-xs sm:text-sm">Trabajos destacados</p>
      </div>
    </div>
    
    <!-- Grid de proyectos mejorado responsive -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6 lg:gap-8">
      {projects.map((project, index) => (
        <article 
          class="group animate-on-scroll" 
          style={`animation-delay: ${index * 0.2}s`}
        >
          <div class="relative worn-border rounded-lg bg-decay-dark/80 backdrop-blur-sm p-4 sm:p-6 md:p-7 subtle-hover h-full flex flex-col shadow-xl shadow-black/50">
            {/* Indicador de proyecto mejorado */}
            <div class="absolute top-4 sm:top-6 right-4 sm:right-6 w-2.5 sm:w-3 h-2.5 sm:h-3 rounded-full bg-accent-ember animate-flicker shadow-[0_0_15px_rgba(255,59,13,0.8)]"></div>
            
            {/* Número de proyecto mejorado responsive */}
            <div class="mb-3 sm:mb-4">
              <span class="text-5xl sm:text-6xl md:text-7xl font-black text-accent-ember/15 group-hover:text-accent-ember/25 transition-colors leading-none">
                0{index + 1}
              </span>
            </div>
            
            {/* Título mejorado responsive */}
            <h3 class="text-xl sm:text-2xl md:text-3xl font-black text-wasteland-sand mb-2 sm:mb-3 group-hover:text-accent-glow transition-colors leading-tight break-words">
              {project.title}
            </h3>
            
            {/* Barra decorativa mejorada */}
            <div class="w-10 sm:w-12 h-0.5 sm:h-1 bg-gradient-to-r from-accent-ember to-accent-amber mb-3 sm:mb-4 group-hover:w-20 sm:group-hover:w-24 transition-all duration-500 shadow-[0_0_8px_rgba(255,59,13,0.4)]"></div>
            
            {/* Descripción mejorada responsive */}
            <p class="text-wasteland-sand/85 mb-4 sm:mb-5 text-xs sm:text-sm leading-relaxed flex-grow">
              {project.description}
            </p>
            
            {/* Tecnologías con mejor diseño responsive */}
            <div class="flex flex-wrap gap-2 sm:gap-2.5 mb-4 sm:mb-5">
              {project.technologies.map((tech) => (
                <span class="px-2.5 sm:px-3 py-1 sm:py-1.5 bg-wasteland-concrete/25 border-2 border-wasteland-metal/60 rounded-lg text-[10px] sm:text-xs font-semibold text-wasteland-sand hover:border-accent-ember/40 hover:bg-accent-ember/5 transition-all shadow-sm hover:shadow-lg hover:shadow-accent-ember/10">
                  {tech}
                </span>
              ))}
            </div>
            
            {/* Links mejorados responsive */}
            <div class="flex flex-wrap gap-2 sm:gap-3 text-sm mt-auto">
              {project.github && (
                <a 
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group/link flex items-center gap-2 sm:gap-2.5 px-3 sm:px-4 py-2 sm:py-2.5 border-2 border-wasteland-concrete hover:border-accent-ember rounded-lg text-wasteland-sand hover:text-accent-ember hover:bg-accent-ember/10 transition-all font-bold uppercase tracking-wide shadow-lg shadow-black/30 hover:shadow-xl hover:shadow-accent-ember/20 active:scale-95 sm:hover:scale-[1.02] text-[11px] sm:text-xs"
                >
                  <svg class="w-4 sm:w-5 h-4 sm:h-5 transform group-hover/link:translate-x-1 group-hover/link:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                  <span>Ver en GitHub</span>
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
