---
import { projects } from '@data/portfolio';
import ImageGallery from './ImageGallery.astro';
---

<section id="projects" class="min-h-screen py-16 sm:py-20 md:py-24 px-4 sm:px-6 relative overflow-hidden">
  <!-- Elemento decorativo mejorado -->
  <div class="absolute top-40 -right-20 sm:right-0 w-72 sm:w-96 h-72 sm:h-96 bg-accent-ember/[0.06] rounded-full blur-3xl pointer-events-none"></div>
  
  <div class="max-w-6xl mx-auto">
    <!-- Título con diseño mejorado responsive -->
    <div class="mb-12 sm:mb-16 md:mb-20 animate-on-scroll">
      <div class="flex flex-col xs:flex-row xs:items-center gap-3 sm:gap-5 mb-4 sm:mb-5">
        <span class="text-accent-ember font-mono text-sm sm:text-base font-bold px-3 sm:px-4 py-1.5 sm:py-2 bg-accent-ember/10 border-2 border-accent-ember/30 rounded-lg shadow-lg shadow-accent-ember/10 w-fit">[ 02 ]</span>
        <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black worn-text text-wasteland-sand">
          Proyectos
        </h2>
      </div>
      <div class="flex items-center gap-3 sm:gap-5 ml-0 xs:ml-16 sm:ml-20">
        <div class="w-16 sm:w-24 h-1 sm:h-1.5 bg-gradient-to-r from-accent-ember via-accent-amber to-transparent shadow-[0_0_15px_rgba(255,59,13,0.3)]"></div>
        <p class="text-wasteland-sand/70 font-medium text-sm sm:text-base">Trabajos destacados</p>
      </div>
    </div>
    
    <!-- Grid de proyectos mejorado responsive -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8 lg:gap-10">
      {projects.map((project, index) => (
        <article 
          class="group animate-on-scroll" 
          style={`animation-delay: ${index * 0.2}s`}
        >
          <div class="relative worn-border rounded-lg bg-decay-dark/80 backdrop-blur-sm p-6 sm:p-8 md:p-10 subtle-hover h-full flex flex-col shadow-xl shadow-black/50">
            {/* Indicador de proyecto mejorado */}
            <div class="absolute top-4 sm:top-6 right-4 sm:right-6 w-2.5 sm:w-3 h-2.5 sm:h-3 rounded-full bg-accent-ember animate-flicker shadow-[0_0_15px_rgba(255,59,13,0.8)]"></div>
            
            {/* Número de proyecto mejorado responsive */}
            <div class="mb-4 sm:mb-6">
              <span class="text-6xl sm:text-7xl md:text-8xl font-black text-accent-ember/15 group-hover:text-accent-ember/25 transition-colors leading-none">
                0{index + 1}
              </span>
            </div>
            
            {/* Título mejorado responsive */}
            <h3 class="text-2xl sm:text-3xl md:text-4xl font-black text-wasteland-sand mb-3 sm:mb-4 group-hover:text-accent-glow transition-colors leading-tight break-words">
              {project.title}
            </h3>
            
            {/* Barra decorativa mejorada */}
            <div class="w-12 sm:w-16 h-0.5 sm:h-1 bg-gradient-to-r from-accent-ember to-accent-amber mb-4 sm:mb-6 group-hover:w-24 sm:group-hover:w-32 transition-all duration-500 shadow-[0_0_10px_rgba(255,59,13,0.4)]"></div>
            
            {/* Descripción mejorada responsive */}
            <p class="text-wasteland-sand/85 mb-6 sm:mb-8 text-sm sm:text-base leading-relaxed flex-grow">
              {project.description}
            </p>
            
            {/* Tecnologías con mejor diseño responsive */}
            <div class="flex flex-wrap gap-2 sm:gap-3 mb-6 sm:mb-8">
              {project.technologies.map((tech) => (
                <span class="px-3 sm:px-4 py-1.5 sm:py-2 bg-wasteland-concrete/25 border-2 border-wasteland-metal/60 rounded-lg text-xs sm:text-sm font-semibold text-wasteland-sand hover:border-accent-ember/40 hover:bg-accent-ember/5 transition-all shadow-sm hover:shadow-lg hover:shadow-accent-ember/10">
                  {tech}
                </span>
              ))}
            </div>
            
            {/* Links mejorados responsive */}
            <div class="flex flex-wrap gap-3 sm:gap-4 text-sm mt-auto">
              {project.github && (
                <a 
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group/link flex items-center gap-2 sm:gap-2.5 px-4 sm:px-5 py-2.5 sm:py-3 bg-accent-ember/10 border-2 border-accent-ember/30 rounded-lg text-accent-ember hover:bg-accent-ember hover:text-white transition-all font-bold uppercase tracking-wide shadow-lg shadow-accent-ember/10 hover:shadow-xl hover:shadow-accent-ember/30 active:scale-95 sm:hover:scale-[1.02] text-xs sm:text-sm"
                >
                  <svg class="w-4 sm:w-5 h-4 sm:h-5 transform group-hover/link:rotate-12 transition-transform" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  <span>GitHub</span>
                </a>
              )}
              
              {project.link && (
                <ImageGallery 
                  projectLink={project.link}
                />
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
