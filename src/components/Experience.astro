---
import { experience } from '@data/portfolio';
---

<section id="experience" class="py-24 px-4 relative">
  <!-- Elemento decorativo mejorado -->
  <div class="absolute top-40 left-0 w-96 h-96 bg-accent-ember/[0.05] rounded-full blur-3xl pointer-events-none"></div>
  
  <div class="max-w-5xl mx-auto">
    <!-- Título mejorado -->
    <div class="mb-20 animate-on-scroll">
      <div class="flex items-center gap-5 mb-5">
        <span class="text-accent-ember font-mono text-base font-bold px-4 py-2 bg-accent-ember/10 border-2 border-accent-ember/30 rounded-lg shadow-lg shadow-accent-ember/10">[ 03 ]</span>
        <h2 class="text-5xl md:text-6xl lg:text-7xl font-black worn-text text-wasteland-sand">
          Experiencia
        </h2>
      </div>
      <div class="flex items-center gap-5 ml-20">
        <div class="w-24 h-1.5 bg-gradient-to-r from-accent-ember via-accent-amber to-transparent shadow-[0_0_15px_rgba(255,59,13,0.3)]"></div>
        <p class="text-wasteland-sand/70 font-medium text-base">Trayectoria profesional</p>
      </div>
    </div>
    
    <!-- Timeline mejorado -->
    <div class="relative">
      {/* Línea vertical decorativa mejorada */}
      <div class="absolute left-0 md:left-10 top-0 bottom-0 w-1 bg-gradient-to-b from-accent-ember via-accent-amber to-transparent hidden md:block shadow-[0_0_15px_rgba(255,59,13,0.3)]"></div>
      
      {/* Items */}
      <div class="space-y-12 md:space-y-16">
        {experience.map((exp, index) => (
          <article 
            class="relative animate-on-scroll"
            style={`animation-delay: ${index * 0.2}s`}
          >
            {/* Indicador en timeline mejorado */}
            <div class="absolute left-0 md:left-[1.625rem] top-10 w-7 h-7 rounded-full border-3 border-accent-ember bg-decay-darker hidden md:flex items-center justify-center shadow-lg shadow-accent-ember/30">
              <div class="w-3 h-3 rounded-full bg-accent-ember animate-glow-pulse shadow-[0_0_15px_rgba(255,59,13,0.8)]"></div>
            </div>
            
            {/* Tarjeta mejorada */}
            <div class="md:ml-28 worn-border rounded-lg p-8 md:p-10 bg-decay-dark/80 backdrop-blur-sm hover:bg-decay-dark/90 transition-all subtle-hover shadow-xl shadow-black/50">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-5 mb-6">
                <div class="flex-1">
                  {/* Título y empresa mejorados */}
                  <h3 class="text-3xl md:text-4xl font-black text-accent-glow mb-3 leading-tight">
                    {exp.position}
                  </h3>
                  <p class="text-wasteland-olive font-bold text-xl flex items-center gap-3">
                    <svg class="w-5 h-5 text-accent-ember" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                    {exp.company}
                  </p>
                </div>
                
                {/* Período mejorado */}
                <span class="inline-flex items-center gap-3 px-5 py-3 bg-accent-ember/10 border-2 border-accent-ember/40 rounded-lg text-sm font-bold text-accent-ember whitespace-nowrap shadow-lg shadow-accent-ember/10">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  {exp.period}
                </span>
              </div>
              
              {/* Barra decorativa mejorada */}
              <div class="w-20 h-1 bg-gradient-to-r from-accent-ember to-accent-amber mb-6 shadow-[0_0_10px_rgba(255,59,13,0.3)]"></div>
              
              {/* Descripción mejorada */}
              <p class="text-wasteland-sand/85 mb-8 text-base md:text-lg leading-relaxed">
                {exp.description}
              </p>
              
              {/* Tecnologías mejoradas */}
              <div>
                <p class="text-xs font-bold text-wasteland-sand/60 uppercase tracking-widest mb-4 flex items-center gap-2">
                  <span class="w-1 h-4 bg-accent-ember"></span>
                  Stack Tecnológico
                </p>
                <div class="flex flex-wrap gap-3">
                  {exp.technologies.map((tech) => (
                    <span class="px-4 py-2 bg-decay-medium/90 border-2 border-wasteland-metal/60 rounded-lg text-sm font-semibold text-wasteland-sand hover:border-accent-ember/40 hover:bg-accent-ember/5 transition-all shadow-sm hover:shadow-lg hover:shadow-accent-ember/10">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
