---
interface Props {
  projectLink?: string;
}

const { projectLink } = Astro.props;

// Si no hay link, no mostramos nada
if (!projectLink) return null;
---

<a 
  href={projectLink}
  target="_blank"
  rel="noopener noreferrer"
  class="group/link flex items-center gap-2 sm:gap-2.5 px-4 sm:px-5 py-2.5 sm:py-3 border-2 border-wasteland-concrete hover:border-accent-ember rounded-lg text-wasteland-sand hover:text-accent-ember hover:bg-accent-ember/10 transition-all font-bold uppercase tracking-wide shadow-lg shadow-black/30 hover:shadow-xl hover:shadow-accent-ember/20 active:scale-95 sm:hover:scale-[1.02] text-xs sm:text-sm"
>
  <svg class="w-4 sm:w-5 h-4 sm:h-5 transform group-hover/link:translate-x-1 group-hover/link:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
  </svg>
  <span>Ver Proyecto</span>
</a>
