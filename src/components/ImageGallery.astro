---
interface Props {
  projectId: string;
  images: string[];
  projectTitle: string;
}

const { projectId, images, projectTitle } = Astro.props;
---

<!-- Botón simple -->
<button 
  type="button"
  onclick={`openModal${projectId}()`}
  class="flex items-center gap-2 px-4 py-2.5 border-2 border-wasteland-concrete hover:border-accent-ember rounded-lg text-wasteland-sand hover:text-accent-ember hover:bg-accent-ember/10 transition-all font-bold uppercase tracking-wide text-xs sm:text-sm shadow-lg shadow-black/30 hover:shadow-xl hover:shadow-accent-ember/20 hover:scale-[1.02] active:scale-95"
>
  <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
  </svg>
  <span>Ver Imágenes ({images.length})</span>
</button>

<!-- Modal super simple -->
<div 
  id={`modal-${projectId}`}
  style="display: none;"
  class="fixed inset-0 bg-black/95 z-[999] flex-col overflow-hidden"
>
  <!-- Header con botón cerrar - mejor posicionado en móvil -->
  <div class="flex-shrink-0 flex items-center justify-between px-4 py-4 sm:py-6 bg-black/50 backdrop-blur-sm z-[1000]">
    <h3 class="text-base sm:text-xl md:text-2xl font-black text-wasteland-sand truncate flex-1 mr-4">{projectTitle}</h3>
    
    <button 
      type="button"
      onclick={`closeModal${projectId}()`}
      class="flex-shrink-0 w-11 h-11 sm:w-12 sm:h-12 rounded-lg border-2 border-accent-ember bg-accent-ember/20 hover:bg-accent-ember/30 active:bg-accent-ember/40 flex items-center justify-center transition-all"
    >
      <svg class="w-6 h-6 text-accent-ember" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Contenedor de imágenes - sin scroll lateral -->
  <div class="flex-1 flex items-center justify-center px-4 py-4 overflow-hidden">
    <div class="relative w-full h-full flex items-center justify-center">
      {images.map((image, index) => (
        <img 
          id={`img-${projectId}-${index}`}
          src={image}
          alt={`${projectTitle} - Imagen ${index + 1}`}
          class="absolute max-w-[90vw] max-h-[60vh] sm:max-h-[65vh] w-auto h-auto object-contain rounded-lg border-2 border-accent-ember/50 shadow-2xl"
          style={index === 0 ? '' : 'display: none;'}
        />
      ))}
    </div>
  </div>

  <!-- Footer con navegación y thumbnails - sin scroll lateral -->
  {images.length > 1 && (
    <div class="flex-shrink-0 bg-black/50 backdrop-blur-sm border-t-2 border-accent-ember/20 z-[1000]">
      <!-- Navegación -->
      <div class="flex items-center justify-center gap-4 py-3 px-4">
        <button 
          type="button"
          onclick={`prevImage${projectId}()`}
          class="w-11 h-11 sm:w-12 sm:h-12 rounded-lg border-2 border-accent-ember bg-accent-ember/20 hover:bg-accent-ember/30 active:bg-accent-ember/40 flex items-center justify-center transition-all"
        >
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-accent-ember" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        
        <span class="text-wasteland-sand font-mono text-sm sm:text-base font-bold min-w-[60px] text-center">
          <span id={`counter-${projectId}`}>1</span> / {images.length}
        </span>
        
        <button 
          type="button"
          onclick={`nextImage${projectId}()`}
          class="w-11 h-11 sm:w-12 sm:h-12 rounded-lg border-2 border-accent-ember bg-accent-ember/20 hover:bg-accent-ember/30 active:bg-accent-ember/40 flex items-center justify-center transition-all"
        >
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-accent-ember" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
      
      <!-- Thumbnails con scroll horizontal controlado -->
      <div class="overflow-x-auto overflow-y-hidden pb-3 px-4" style="scrollbar-width: thin;">
        <div class="flex gap-2 justify-center sm:justify-start min-w-min">
          {images.map((image, index) => (
            <button
              type="button"
              onclick={`showImage${projectId}(${index})`}
              id={`thumb-${projectId}-${index}`}
              class="flex-shrink-0 w-14 h-14 sm:w-16 sm:h-16 rounded-lg overflow-hidden border-2 transition-all active:scale-95"
              class:list={[index === 0 ? 'border-accent-ember shadow-lg shadow-accent-ember/40' : 'border-wasteland-concrete/40']}
            >
              <img 
                src={image}
                alt={`Thumbnail ${index + 1}`}
                class="w-full h-full object-cover"
              />
            </button>
          ))}
        </div>
      </div>
    </div>
  )}
</div>

<script define:vars={{ projectId, totalImages: images.length }}>
  let currentIndex = 0;
  
  // Función para abrir modal
  window[`openModal${projectId}`] = function() {
    const modal = document.getElementById(`modal-${projectId}`);
    if (modal) {
      modal.style.display = 'flex';
      // Bloquear scroll del body
      document.body.style.overflow = 'hidden';
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
      document.body.style.height = '100%';
    }
  };
  
  // Función para cerrar modal
  window[`closeModal${projectId}`] = function() {
    const modal = document.getElementById(`modal-${projectId}`);
    if (modal) {
      modal.style.display = 'none';
      // Restaurar scroll del body
      document.body.style.overflow = '';
      document.body.style.position = '';
      document.body.style.width = '';
      document.body.style.height = '';
      currentIndex = 0;
    }
  };
  
  window[`showImage${projectId}`] = function(index) {
    // Ocultar todas las imágenes
    for (let i = 0; i < totalImages; i++) {
      const img = document.getElementById(`img-${projectId}-${i}`);
      if (img) img.style.display = 'none';
      
      // Actualizar estilos de thumbnails
      const thumb = document.getElementById(`thumb-${projectId}-${i}`);
      if (thumb) {
        if (i === index) {
          thumb.classList.add('border-accent-ember', 'shadow-lg', 'shadow-accent-ember/40');
          thumb.classList.remove('border-wasteland-concrete/40');
        } else {
          thumb.classList.remove('border-accent-ember', 'shadow-lg', 'shadow-accent-ember/40');
          thumb.classList.add('border-wasteland-concrete/40');
        }
      }
    }
    
    // Mostrar la imagen seleccionada
    const selectedImg = document.getElementById(`img-${projectId}-${index}`);
    if (selectedImg) selectedImg.style.display = 'block';
    
    // Actualizar contador
    const counter = document.getElementById(`counter-${projectId}`);
    if (counter) counter.textContent = (index + 1).toString();
    
    currentIndex = index;
  };
  
  window[`nextImage${projectId}`] = function() {
    const nextIndex = (currentIndex + 1) % totalImages;
    window[`showImage${projectId}`](nextIndex);
  };
  
  window[`prevImage${projectId}`] = function() {
    const prevIndex = (currentIndex - 1 + totalImages) % totalImages;
    window[`showImage${projectId}`](prevIndex);
  };
  
  // Cerrar con ESC
  document.addEventListener('keydown', function(e) {
    const modal = document.getElementById(`modal-${projectId}`);
    if (modal && modal.style.display === 'flex' && e.key === 'Escape') {
      window[`closeModal${projectId}`]();
    }
  });
  
  // Swipe en móvil
  let touchStartX = 0;
  let touchEndX = 0;
  
  const modal = document.getElementById(`modal-${projectId}`);
  if (modal) {
    modal.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    
    modal.addEventListener('touchend', function(e) {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      
      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          window[`nextImage${projectId}`]();
        } else {
          window[`prevImage${projectId}`]();
        }
      }
    }, { passive: true });
  }
</script>

<style>
  /* Prevenir scroll lateral */
  body {
    overflow-x: hidden;
  }
  
  /* Estilos del scrollbar para thumbnails */
  [id^="modal-"] {
    -webkit-overflow-scrolling: touch;
  }
</style>
