---
interface Props {
  projectId: string;
  images: string[];
  projectTitle: string;
}

const { projectId, images, projectTitle } = Astro.props;
---

<!-- Botón simple -->
<button 
  type="button"
  onclick={`document.getElementById('modal-${projectId}').style.display='flex'`}
  class="flex items-center gap-2 px-4 py-2.5 border-2 border-wasteland-concrete hover:border-accent-ember rounded-lg text-wasteland-sand hover:text-accent-ember hover:bg-accent-ember/10 transition-all font-bold uppercase tracking-wide text-xs sm:text-sm shadow-lg shadow-black/30 hover:shadow-xl hover:shadow-accent-ember/20 hover:scale-[1.02] active:scale-95"
>
  <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
  </svg>
  <span>Ver Imágenes ({images.length})</span>
</button>

<!-- Modal super simple -->
<div 
  id={`modal-${projectId}`}
  style="display: none;"
  class="fixed inset-0 bg-black/95 z-[999] flex-col items-center justify-center p-4"
>
  <!-- Botón cerrar -->
  <button 
    type="button"
    onclick={`document.getElementById('modal-${projectId}').style.display='none'`}
    class="absolute top-4 right-4 z-[1000] w-12 h-12 rounded-lg border-2 border-accent-ember bg-accent-ember/20 hover:bg-accent-ember/30 flex items-center justify-center transition-all"
  >
    <svg class="w-6 h-6 text-accent-ember" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <!-- Título -->
  <div class="text-center mb-4 z-[1000]">
    <h3 class="text-xl sm:text-2xl font-black text-wasteland-sand">{projectTitle}</h3>
  </div>

  <!-- Contenedor de imágenes -->
  <div class="flex-1 flex items-center justify-center max-w-7xl w-full">
    {images.map((image, index) => (
      <img 
        id={`img-${projectId}-${index}`}
        src={image}
        alt={`${projectTitle} - Imagen ${index + 1}`}
        class="max-w-full max-h-[70vh] object-contain rounded-lg border-2 border-accent-ember/50"
        style={index === 0 ? '' : 'display: none;'}
      />
    ))}
  </div>

  <!-- Navegación -->
  {images.length > 1 && (
    <div class="flex items-center gap-4 mt-6 z-[1000]">
      <button 
        type="button"
        onclick={`prevImage${projectId}()`}
        class="w-12 h-12 rounded-lg border-2 border-accent-ember bg-accent-ember/20 hover:bg-accent-ember/30 flex items-center justify-center transition-all"
      >
        <svg class="w-6 h-6 text-accent-ember" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
      
      <span class="text-wasteland-sand font-mono">
        <span id={`counter-${projectId}`}>1</span> / {images.length}
      </span>
      
      <button 
        type="button"
        onclick={`nextImage${projectId}()`}
        class="w-12 h-12 rounded-lg border-2 border-accent-ember bg-accent-ember/20 hover:bg-accent-ember/30 flex items-center justify-center transition-all"
      >
        <svg class="w-6 h-6 text-accent-ember" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  )}

  <!-- Thumbnails -->
  {images.length > 1 && (
    <div class="flex gap-2 mt-4 overflow-x-auto z-[1000] max-w-full px-4">
      {images.map((image, index) => (
        <button
          type="button"
          onclick={`showImage${projectId}(${index})`}
          class="flex-shrink-0 w-16 h-16 sm:w-20 sm:h-20 rounded-lg overflow-hidden border-2 border-wasteland-concrete/40 hover:border-accent-ember transition-all"
        >
          <img 
            src={image}
            alt={`Thumbnail ${index + 1}`}
            class="w-full h-full object-cover"
          />
        </button>
      ))}
    </div>
  )}
</div>

<script define:vars={{ projectId, totalImages: images.length }}>
  let currentIndex = 0;
  
  window[`showImage${projectId}`] = function(index) {
    // Ocultar todas las imágenes
    for (let i = 0; i < totalImages; i++) {
      const img = document.getElementById(`img-${projectId}-${i}`);
      if (img) img.style.display = 'none';
    }
    
    // Mostrar la imagen seleccionada
    const selectedImg = document.getElementById(`img-${projectId}-${index}`);
    if (selectedImg) selectedImg.style.display = 'block';
    
    // Actualizar contador
    const counter = document.getElementById(`counter-${projectId}`);
    if (counter) counter.textContent = (index + 1).toString();
    
    currentIndex = index;
  };
  
  window[`nextImage${projectId}`] = function() {
    const nextIndex = (currentIndex + 1) % totalImages;
    window[`showImage${projectId}`](nextIndex);
  };
  
  window[`prevImage${projectId}`] = function() {
    const prevIndex = (currentIndex - 1 + totalImages) % totalImages;
    window[`showImage${projectId}`](prevIndex);
  };
  
  // Cerrar con ESC
  document.addEventListener('keydown', function(e) {
    const modal = document.getElementById(`modal-${projectId}`);
    if (modal && modal.style.display === 'flex' && e.key === 'Escape') {
      modal.style.display = 'none';
    }
  });
</script>
