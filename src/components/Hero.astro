---
import { personalInfo } from '@data/portfolio';
---

<section id="hero" class="min-h-screen flex items-center justify-center px-4 pt-20 pb-16 relative">
  <!-- Elementos decorativos de fondo mejorados -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 right-10 w-[500px] h-[500px] bg-accent-ember/[0.08] rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-20 left-10 w-[400px] h-[400px] bg-accent-ember/[0.05] rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
  </div>
  
  <div class="max-w-7xl mx-auto relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Columna izquierda: Contenido -->
      <div class="order-2 lg:order-1">
        <!-- Badge superior mejorado -->
        <div class="mb-8 animate-fade-in">
          <span class="inline-flex items-center gap-2 px-5 py-2.5 border-2 border-accent-ember/40 rounded-full text-sm font-semibold uppercase tracking-wider text-accent-ember bg-accent-ember/8 backdrop-blur-md shadow-lg shadow-accent-ember/10">
            <span class="w-2 h-2 rounded-full bg-accent-ember animate-flicker shadow-[0_0_10px_rgba(255,59,13,0.8)]"></span>
            Disponible para proyectos
          </span>
        </div>
    
        <!-- Título principal mejorado -->
        <div class="mb-10">
          <h1 class="text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-black mb-6 worn-text text-wasteland-sand leading-[1.1] animate-fade-up" style="animation-delay: 0.2s;">
            {personalInfo.name}
          </h1>
          
          <!-- Barra decorativa mejorada -->
          <div class="flex items-center gap-5 mb-6 animate-slide-in-left" style="animation-delay: 0.4s;">
            <div class="h-1.5 w-20 bg-gradient-to-r from-accent-ember via-accent-amber to-transparent shadow-[0_0_15px_rgba(255,59,13,0.3)]"></div>
            <p class="text-2xl md:text-3xl lg:text-4xl font-black text-accent-ember font-mono uppercase tracking-wide">
              {personalInfo.title}
            </p>
          </div>
          
          <p class="text-lg md:text-xl lg:text-2xl text-wasteland-sand/80 font-medium italic animate-fade-in leading-relaxed" style="animation-delay: 0.6s;">
            "{personalInfo.tagline}"
          </p>
        </div>
        
        <!-- Descripción mejorada -->
        <div class="max-w-2xl mb-12 animate-fade-up" style="animation-delay: 0.8s;">
          <p class="text-wasteland-sand text-base md:text-lg leading-relaxed border-l-4 border-accent-ember/40 pl-6 shadow-[-4px_0_15px_rgba(255,59,13,0.1)]">
            {personalInfo.bio}
          </p>
        </div>
        
        <!-- CTA Buttons mejorados -->
        <div class="flex flex-col sm:flex-row gap-4 mb-14 animate-fade-up" style="animation-delay: 1s;">
          <a 
            href="#projects"
            class="group relative px-8 py-4 border-2 border-accent-ember rounded-lg bg-accent-ember hover:bg-accent-ember/90 font-bold text-sm uppercase tracking-wider transition-all duration-300 text-center overflow-hidden text-white shadow-lg shadow-accent-ember/30 hover:shadow-xl hover:shadow-accent-ember/40 hover:scale-[1.02]"
          >
            <span class="relative z-10 flex items-center justify-center gap-2.5">
              <span>Ver Proyectos</span>
              <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </span>
            <div class="absolute inset-0 bg-gradient-to-r from-accent-ember via-accent-glow to-accent-ember transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </a>
          
          <a 
            href="#contact"
            class="group px-8 py-4 border-2 border-wasteland-concrete hover:border-accent-ember rounded-lg bg-transparent hover:bg-accent-ember/10 font-bold text-sm uppercase tracking-wider transition-all duration-300 text-center text-wasteland-sand hover:text-accent-ember shadow-lg shadow-black/30 hover:shadow-xl hover:shadow-accent-ember/20 hover:scale-[1.02]"
          >
            <span class="flex items-center justify-center gap-2.5">
              <span>Contacto</span>
              <svg class="w-4 h-4 group-hover:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </span>
          </a>
        </div>
        
        <!-- Social Links mejorados -->
        <div class="flex gap-4 animate-fade-in" style="animation-delay: 1.2s;">
          <a 
            href={personalInfo.social.github}
            target="_blank"
            rel="noopener noreferrer"
            class="group w-12 h-12 rounded-lg border-2 border-wasteland-concrete hover:border-accent-ember flex items-center justify-center transition-all duration-300 hover:bg-accent-ember/10 hover:-translate-y-1 shadow-lg shadow-black/30 hover:shadow-xl hover:shadow-accent-ember/20"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5 text-wasteland-sand/70 group-hover:text-accent-ember transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          
          <a 
            href={personalInfo.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="group w-12 h-12 rounded-lg border-2 border-wasteland-concrete hover:border-accent-ember flex items-center justify-center transition-all duration-300 hover:bg-accent-ember/10 hover:-translate-y-1 shadow-lg shadow-black/30 hover:shadow-xl hover:shadow-accent-ember/20"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5 text-wasteland-sand/70 group-hover:text-accent-ember transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          
          <a 
            href={personalInfo.social.email}
            class="group w-12 h-12 rounded-lg border-2 border-wasteland-concrete hover:border-accent-ember flex items-center justify-center transition-all duration-300 hover:bg-accent-ember/10 hover:-translate-y-1 shadow-lg shadow-black/30 hover:shadow-xl hover:shadow-accent-ember/20"
            aria-label="Email"
          >
            <svg class="w-5 h-5 text-wasteland-sand/70 group-hover:text-accent-ember transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Columna derecha: Foto mejorada -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative animate-fade-in" style="animation-delay: 0.3s;">
          <!-- Elementos decorativos de fondo mejorados -->
          <div class="absolute -inset-6 bg-gradient-to-br from-accent-ember/25 via-accent-amber/15 to-transparent blur-3xl opacity-60 animate-glow-pulse"></div>
          
          <!-- Marco con efecto mejorado -->
          <div class="relative">
            <!-- Esquinas decorativas mejoradas -->
            <div class="absolute -top-3 -left-3 w-10 h-10 border-l-[3px] border-t-[3px] border-accent-ember shadow-[0_0_15px_rgba(255,59,13,0.4)]"></div>
            <div class="absolute -top-3 -right-3 w-10 h-10 border-r-[3px] border-t-[3px] border-accent-ember shadow-[0_0_15px_rgba(255,59,13,0.4)]"></div>
            <div class="absolute -bottom-3 -left-3 w-10 h-10 border-l-[3px] border-b-[3px] border-accent-ember shadow-[0_0_15px_rgba(255,59,13,0.4)]"></div>
            <div class="absolute -bottom-3 -right-3 w-10 h-10 border-r-[3px] border-b-[3px] border-accent-ember shadow-[0_0_15px_rgba(255,59,13,0.4)]"></div>
            
            <!-- Contenedor de la imagen mejorado -->
            <div class="relative w-80 h-80 md:w-96 md:h-96 lg:w-[450px] lg:h-[450px]">
              <!-- Borde con efecto de brillo mejorado -->
              <div class="absolute inset-0 worn-border rounded-lg bg-gradient-to-br from-decay-medium to-decay-dark overflow-hidden group hover:border-accent-ember/60 transition-all duration-500 shadow-2xl shadow-black/60">
                <!-- Tu foto aquí -->
                <img 
                  src="/profile.jpg" 
                  alt={personalInfo.name}
                  class="w-full h-full object-cover object-center opacity-95 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500 filter"
                />
                
                <!-- Overlay mejorado -->
                <div class="absolute inset-0 bg-gradient-to-t from-decay-darker/50 via-transparent to-transparent pointer-events-none"></div>
                
                <!-- Efecto de brillo al hover mejorado -->
                <div class="absolute inset-0 bg-gradient-to-tr from-accent-ember/0 via-accent-ember/15 to-accent-ember/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
              </div>
              
              <!-- Líneas decorativas mejoradas -->
              <div class="absolute -bottom-6 -right-6 w-40 h-40 border-r-2 border-b-2 border-accent-ember/30 pointer-events-none shadow-[0_0_15px_rgba(255,59,13,0.2)]"></div>
              <div class="absolute -top-6 -left-6 w-32 h-32 border-l-2 border-t-2 border-accent-ember/30 pointer-events-none shadow-[0_0_15px_rgba(255,59,13,0.2)]"></div>
            </div>
          </div>
          
          <!-- Badge decorativo mejorado -->
          <div class="absolute -bottom-8 left-1/2 transform -translate-x-1/2 px-8 py-3 bg-decay-darker/95 border-2 border-accent-ember/50 rounded-full backdrop-blur-md shadow-2xl shadow-accent-ember/20">
            <span class="text-accent-ember text-sm font-bold uppercase tracking-wider flex items-center gap-3">
              <span class="w-2.5 h-2.5 rounded-full bg-accent-ember animate-flicker shadow-[0_0_12px_rgba(255,59,13,0.8)]"></span>
              Desarrollador
            </span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Scroll indicator mejorado -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce lg:block hidden">
      <div class="flex flex-col items-center gap-2 opacity-60 hover:opacity-100 transition-opacity cursor-pointer" onclick="document.getElementById('projects').scrollIntoView({ behavior: 'smooth' })">
        <span class="text-xs font-mono uppercase tracking-wider text-wasteland-sand">Scroll</span>
        <svg class="w-5 h-5 text-accent-ember drop-shadow-[0_0_8px_rgba(255,59,13,0.6)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
    </div>
  </div>
</section>
